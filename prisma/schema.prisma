  RIVER_VIEW
  LANDMARK_VIEW
  CITY_VIEW
}


model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique @db.VarChar(64)
  password   String   @db.VarChar(255)
  role       Role     @default(MERCHANT)
  created_at DateTime @default(now())
  hotels Hotel[]
}

model Hotel {
  id              Int      @id @default(autoincrement())
  merchantId      Int      @map("merchant_id")
  merchant        User     @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  // 1. 名称信息 (Base)
  nameCn          String   @db.VarChar(128) @map("name_cn")
  nameEn          String   @db.VarChar(128) @map("name_en")

  // 2. 图片信息 (Images)
  // 存储多张图片 URL 数组，对应你说的左右移动
  imageUrls       Json     @map("image_urls") 

  // 3. 星级与评分 (Level & Comment)
  starRating      Int      @default(2) @map("star_rating")
  score           Decimal  @default(0.0) @db.Decimal(2, 1)
  totalReviews    Int      @default(0) @map("total_reviews")

  // 4. 价格与货币 (Money)
  // 这里的 price 通常作为酒店起步价展示
  price           Decimal  @db.Decimal(10, 2)
  crossLinePrice  Decimal? @db.Decimal(10, 2) @map("cross_line_price")
  currency        String   @default("RMB") @db.VarChar(10)

  // 5. 标签与位置 (Tags & Position)
  // 存储 HotelTag 枚举数组: ["FREE_WIFI", "GYM"]
  shortTags       Json?    @map("short_tags") 
  latitude        Decimal  @db.Decimal(9, 6)
  longitude       Decimal  @db.Decimal(9, 6)
  address         String   @db.VarChar(255)
  cityCode        String   @db.VarChar(32) @map("city_code")

  // 6. 管理状态
  status          Int      @default(0) @db.TinyInt
  auditReason     String?  @db.VarChar(255) @map("audit_reason")
  openingDate     DateTime @db.Date @map("opening_date")
  created_at      DateTime @default(now())

  // 关联
  rooms           Room[]

  @@index([merchantId])
  @@index([cityCode])
  @@index([status])
  @@map("hotel")
}

model Room {
  id            Int      @id @default(autoincrement())
  hotelId       Int      @map("hotel_id")
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  // 1. 房型基础描述
  name          String   @db.VarChar(64)
  areaTitle     String   @db.VarChar(32) @map("area_title")
  bedTitle      String   @db.VarChar(64) @map("bed_title")
  windowTitle   String   @db.VarChar(32) @map("window_title")
  floorTitle    String   @db.VarChar(32) @map("floor_title")
  smokeTitle    String   @db.VarChar(32) @map("smoke_title")
  wifiInfo      String?  @db.VarChar(64) @map("wifi_info")
  pictureUrl    String   @db.VarChar(255) @map("picture_url")

  // 2. 分组设施字段 (使用 Json 存储对应的枚举数组)
  cleaningFacilities   Json? @map("cleaning_facilities")   // 清洁服务
  bathingFacilities    Json? @map("bathing_facilities")    // 洗浴用品
  layoutFacilities     Json? @map("layout_facilities")     // 客房布局
  accessibleFacilities Json? @map("accessible_facilities") // 无障碍
  networkFacilities    Json? @map("network_facilities")    // 网络通讯
  bathroomFacilities   Json? @map("bathroom_facilities")   // 卫浴设施
  foodFacilities       Json? @map("food_facilities")       // 食品饮品
  childFacilities      Json? @map("child_facilities")      // 儿童设施
  mediaFacilities      Json? @map("media_facilities")      // 媒体科技
  roomSpecFacilities   Json? @map("room_spec_facilities")  // 客房设施
  kitchenFacilities    Json? @map("kitchen_facilities")    // 厨房用品
  amenityFacilities    Json? @map("amenity_facilities")    // 便利设施
  viewFacilities       Json? @map("view_facilities")       // 室外景观

  // 3. 销售核心
  capacity      Int      @default(2)
  price         Decimal  @db.Decimal(10, 2)
  totalStock    Int      @default(0) @map("total_stock")

  inventories   RoomInventory[]

  @@index([hotelId])
  @@map("room")
}

model RoomInventory {
  id             Int      @id @default(autoincrement())
  roomId         Int      @map("room_id")
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  date           DateTime @db.Date
  availableCount Int      @default(0) @map("available_count")
  price          Decimal  @db.Decimal(10, 2) // 每日动态价格

  @@unique([roomId, date])
  @@index([date])
  @@map("room_inventory")
}
